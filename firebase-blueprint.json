{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Thông tin nhân viên hoặc admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "Công việc được giao cho nhân viên SEO",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "assignedTo", "status"]
    },
    "LocationUpdate": {
      "title": "Location Update",
      "description": "Lịch sử vị trí của nhân viên",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "lat", "lng", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Thông tin chi tiết người dùng"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Danh sách công việc"
    },
    "/locations/{locationId}": {
      "schema": "LocationUpdate",
      "description": "Lịch sử vị trí real-time"
    }
  }
}
